{
    "name": "hypervel/foundation",
    "description": "The Foundation package for Hypervel.",
    "license": "MIT",
    "keywords": [
        "php",
        "hyperf",
        "foundation",
        "swoole",
        "hypervel"
    ],
    "support": {
        "issues": "https://github.com/hypervel/components/issues",
        "source": "https://github.com/hypervel/components"
    },
    "authors": [
        {
            "name": "Albert Chen",
            "email": "albert@hypervel.org"
        }
    ],
    "require": {
        "php": "^8.2",
        "nesbot/carbon": "^2.72.6",
        "hypervel/core": "dev-main",
        "hypervel/filesystem": "dev-main",
        "hypervel/support": "dev-main",
        "hypervel/http": "dev-main",
        "hyperf/config": "dev-3.2",
        "hyperf/di": "dev-3.2",
        "hyperf/support": "dev-3.2",
        "hyperf/command": "dev-3.2",
        "hyperf/collection": "dev-3.2",
        "hyperf/context": "dev-3.2",
        "hyperf/http-server": "dev-3.2",
        "hyperf/stringable": "dev-3.2",
        "hyperf/dispatcher": "dev-3.2",
        "hyperf/database": "dev-3.2",
        "hyperf/contract": "dev-3.2",
        "hyperf/signal": "dev-3.2",
        "hyperf/engine": "^2.1",
        "hyperf/db-connection": "dev-3.2",
        "hyperf/validation": "dev-3.2",
        "hyperf/framework": "dev-3.2",
        "friendsofhyperf/pretty-console": "dev-3.2",
        "friendsofhyperf/command-signals": "dev-3.2",
        "symfony/error-handler": "^6.3"
    },
    "require-dev": {
        "hyperf/testing": "~3.1.0"
    },
    "autoload": {
        "psr-4": {
            "Hypervel\\Foundation\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "extra": {
        "hyperf": {
            "config": "Hypervel\\Foundation\\ConfigProvider"
        },
        "hypervel" : {
            "providers": [
                "Hypervel\\Foundation\\Providers\\FoundationServiceProvider"
            ]
        },
        "branch-alias": {
            "dev-main": "0.1-dev"
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "repositories": [
        {
            "type": "github",
            "url": "https://github.com/kingIZZZY/core" 
        },
        {
            "type": "github",
            "url": "https://github.com/kingIZZZY/support" 
        },
        {
            "type": "github",
            "url": "https://github.com/kingIZZZY/filesystem" 
        },
        {
            "type": "github",
            "url": "https://github.com/kingIZZZY/http" 
        }
    ]
}
